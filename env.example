# Copia este archivo a .env (junto a app.py) y reinicia: python app.py
# En la nube ver DEPLOY.md (Render, variables de producción).

# Flask
FLASK_SECRET_KEY=cambia-esto-en-produccion
FLASK_DEBUG=1
PORT=3000
# Producción (HTTPS): FLASK_DEBUG=0, SESSION_COOKIE_SECURE=true, TRUST_PROXY=true, DATA_DIR=/var/data
# Si frontend y backend están separados (Vercel + Render):
# FRONTEND_ORIGIN=https://tu-frontend.vercel.app
# CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app
# SESSION_COOKIE_SAMESITE=None

# URL usada en el enlace del correo de recuperación (sin barra final)
PUBLIC_BASE_URL=http://127.0.0.1:3000

# =============================================================================
# Recuperar contraseña — elige UNA opción
# =============================================================================

# --- Opción B (recomendada en tu PC): sin Gmail ni SMTP ---
# El enlace para nueva contraseña aparece en la pantalla tras enviar el formulario.
# NO uses MAIL_DEBUG=1 en un servidor público en internet.
MAIL_DEBUG=1

# --- Opción A: correo real (Gmail, Outlook, hosting, etc.) ---
# Comenta MAIL_DEBUG=1 arriba y descomenta / rellena lo siguiente:
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_USERNAME=tu_correo@gmail.com
# MAIL_PASSWORD=contraseña_de_aplicacion_de_google
# MAIL_DEFAULT_SENDER=Tecnocambia <tu_correo@gmail.com>
#
# Gmail: https://support.google.com/accounts/answer/185833 (contraseña de aplicación)
#
# Puerto 465 + SSL en algunos proveedores:
# MAIL_PORT=465
# MAIL_USE_TLS=false
# MAIL_USE_SSL=true
